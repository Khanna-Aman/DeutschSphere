# scripts/ — the public repo ships only the active gates/tools that CI and
# contributors actually use. The one-off data-generation pipeline, migration
# scripts, and large intermediate artifacts are archived locally (kept on the
# maintainer's disk, not published). Whitelist the keepers:
scripts/*
!scripts/validate_data.py
!scripts/check_example_originality.py
!scripts/check_grammar_languagetool.py
!scripts/check_image_word_clip.py
!scripts/check_examples_llm_judge.py
!scripts/apply_examples.py
!scripts/vendor_fonts.py

# Orphaned config template (only the archived generation scripts used it)
.env.example

# Internal working docs — kept locally, NOT published to the public repo.
# (The public repo ships only what helps users/contributors; these are for maintainers.)
AGENTS.md
backlog.md
PRODUCTION_READINESS_AUDIT_*.md
COMPETITIVE_ANALYSIS_*.md

# AI Orchestrations & Agent Planning
implementation_plan.md
sprint_handoff_a2_b1.md
audit_a2.html
audit*.html




# Node tooling (dev-only; runtime stays zero-dependency)
node_modules/
package-lock.json

