# ==============================================================================
# DeutschSphere — Environmental Variables Template (.env.example)
# ==============================================================================
# Copy this file to .env and configure with your Google Cloud Vertex AI settings:
# cp .env.example .env
# ==============================================================================

# Google Cloud Service Account Credentials
# Path to your Google Cloud service account JSON Key file located in the workspace root.
# This file is git-ignored by default to prevent accidental credential leakage.
GOOGLE_APPLICATION_CREDENTIALS=antigravity-key.json

# Google Cloud Project Identifier
# Specify the GCP project ID where the Vertex AI and Imagen 3 APIs are enabled.
GCP_PROJECT=your-gcp-project-id

# Google Cloud region/location
# Specify the region for Vertex AI endpoints (e.g., us-central1, europe-west3).
GCP_LOCATION=us-central1
